{
  "$schema": "https://raw.githubusercontent.com/vapor64/GMDF/master/documentation.schema.json",
  "format": 1,
  "modName": "{{i18n:modName}}",
  "pages": [
    {
      "name": "{{i18n:page.overview}}",
      "entries": [
        {
          "type": "divider",
          "style": "iconCentered"
        },
        {
          "type": "sectionTitle",
          "text": "{{i18n:section.overview}}"
        },
        {
          "type": "paragraph",
          "text": "{{i18n:overview.intro}}"
        },
        {
          "type": "list",
          "items": [
            "{{i18n:list.item1}}",
            "{{i18n:list.item2}}",
            "{{i18n:list.item3}}"
          ]
        },
        {
          "type": "divider",
          "style": "dotted"
        },
        {
          "type": "sectionTitle",
          "text": "{{i18n:section.details}}"
        },
        {
          "type": "orderedList",
          "items": [
            "{{i18n:details.step1}}",
            "{{i18n:details.step2}}",
            "{{i18n:details.step3}}"
          ]
        },
        {
          "type": "divider"
        },
        {
          "type": "row",
          "left": [
            {
              "type": "spoiler",
              "label": "{{i18n:spoiler.label}}",
              "text": "{{i18n:spoiler.text}}"
            }
          ],
          "right": [
            {
              "type": "keyValue",
              "key": "{{i18n:kv.key1}}",
              "value": "{{i18n:kv.val1}}"
            },
            {
              "type": "keyValue",
              "key": "{{i18n:kv.key2}}",
              "value": "{{i18n:kv.val2}}"
            }
          ]
        },
        {
          "type": "caption",
          "text": "{{i18n:caption.footer}}"
        },
        {
          "type": "divider",
          "style": "dotted"
        },
        {
          "type": "link",
          "text": "{{i18n:link.nexus}}",
          "url": "https://www.nexusmods.com/stardewvalley"
        },
        {
          "type": "divider",
          "style": "double"
        },
        {
          "type": "sectionTitle",
          "text": "Indent Block Tests"
        },
        {
          "type": "paragraph",
          "text": "A basic indent block (32px) containing a paragraph and a list."
        },
        {
          "type": "indentBlock",
          "entries": [
            {
              "type": "paragraph",
              "text": "Level 1 — this paragraph is indented 32px."
            },
            {
              "type": "list",
              "items": [
                "Indented bullet one",
                "Indented bullet two"
              ]
            }
          ]
        },
        {
          "type": "spacer",
          "height": 8
        },
        {
          "type": "paragraph",
          "text": "Two levels of nesting — each indentBlock adds 32px on top of the previous."
        },
        {
          "type": "indentBlock",
          "indent": 32,
          "entries": [
            {
              "type": "paragraph",
              "text": "Level 1 — outer indent block."
            },
            {
              "type": "indentBlock",
              "indent": 32,
              "entries": [
                {
                  "type": "paragraph",
                  "text": "Level 2 — nested 64px from the left edge."
                },
                {
                  "type": "list",
                  "items": [
                    "Nested bullet one",
                    "Nested bullet two"
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "spacer",
          "height": 8
        },
        {
          "type": "paragraph",
          "text": "Three levels of nesting with mixed entry types at each depth."
        },
        {
          "type": "indentBlock",
          "indent": 32,
          "entries": [
            {
              "type": "sectionTitle",
              "text": "Level 1"
            },
            {
              "type": "keyValue",
              "key": "Category",
              "value": "Weapon"
            },
            {
              "type": "indentBlock",
              "indent": 32,
              "entries": [
                {
                  "type": "sectionTitle",
                  "text": "Level 2"
                },
                {
                  "type": "keyValue",
                  "key": "Damage",
                  "value": "25"
                },
                {
                  "type": "keyValue",
                  "key": "Speed",
                  "value": "1.4x"
                },
                {
                  "type": "indentBlock",
                  "indent": 32,
                  "entries": [
                    {
                      "type": "sectionTitle",
                      "text": "Level 3"
                    },
                    {
                      "type": "spoiler",
                      "label": "Drop table",
                      "text": "Coal (40%), Gold Ore (25%), Diamond (5%), Nothing (30%)"
                    },
                    {
                      "type": "caption",
                      "text": "Deepest nesting level — 96px from the left edge."
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
