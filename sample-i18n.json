{
  "$schema": "https://raw.githubusercontent.com/vapor64/GMDF/master/documentation.schema.json",
  "format": 1,
  "modName": "{{i18n:modName}}",
  "pages": [
    {
      "id": "overview",
      "name": "{{i18n:page.overview}}",
      "entries": [
        {
          "type": "divider",
          "style": "iconCentered"
        },
        {
          "type": "sectionTitle",
          "text": "{{i18n:section.overview}}"
        },
        {
          "type": "paragraph",
          "text": "{{i18n:overview.intro}}"
        },
        {
          "type": "list",
          "items": [
            "{{i18n:list.item1}}",
            "{{i18n:list.item2}}",
            "{{i18n:list.item3}}"
          ]
        },
        {
          "type": "divider",
          "style": "dotted"
        },
        {
          "type": "sectionTitle",
          "text": "{{i18n:section.details}}"
        },
        {
          "type": "orderedList",
          "items": [
            "{{i18n:details.step1}}",
            "{{i18n:details.step2}}",
            "{{i18n:details.step3}}"
          ]
        },
        {
          "type": "divider"
        },
        {
          "type": "row",
          "left": [
            {
              "type": "spoiler",
              "label": "{{i18n:spoiler.label}}",
              "text": "{{i18n:spoiler.text}}"
            }
          ],
          "right": [
            {
              "type": "keyValue",
              "key": "{{i18n:kv.key1}}",
              "value": "{{i18n:kv.val1}}"
            },
            {
              "type": "keyValue",
              "key": "{{i18n:kv.key2}}",
              "value": "{{i18n:kv.val2}}"
            }
          ]
        },
        {
          "type": "caption",
          "text": "{{i18n:caption.footer}}"
        },
        {
          "type": "divider",
          "style": "dotted"
        },
        {
          "type": "link",
          "text": "{{i18n:link.nexus}}",
          "url": "https://www.nexusmods.com/stardewvalley"
        },
        {
          "type": "internalLink",
          "text": "{{i18n:link.internal}}",
          "page": "details",
          "anchor": "crafting-anchor"
        },
        {
          "type": "divider",
          "style": "double"
        },
        {
          "type": "sectionTitle",
          "text": "Indent Block"
        },
        {
          "type": "paragraph",
          "text": "An indent block groups related content with a visual left rule and offset."
        },
        {
          "type": "indentBlock",
          "entries": [
            {
              "type": "paragraph",
              "text": "This paragraph is indented 32px from the left edge. Content inside an indent block wraps within the reduced width."
            },
            {
              "type": "list",
              "items": [
                "Indented bullet one",
                "Indented bullet two"
              ]
            },
            {
              "type": "indentBlock",
              "indent": 32,
              "entries": [
                {
                  "type": "paragraph",
                  "text": "A nested indent block adds another 32px, useful for sub-categories or step breakdowns."
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "details",
      "name": "{{i18n:page.details}}",
      "entries": [
        {
          "type": "divider",
          "style": "iconCentered"
        },
        {
          "type": "sectionTitle",
          "text": "{{i18n:section.crafting}}",
          "anchor": "crafting-anchor"
        },
        {
          "type": "paragraph",
          "text": "{{i18n:crafting.intro}}"
        },
        {
          "type": "keyValue",
          "key": "{{i18n:kv.key1}}",
          "value": "{{i18n:kv.val1}}"
        },
        {
          "type": "keyValue",
          "key": "{{i18n:kv.key2}}",
          "value": "{{i18n:kv.val2}}"
        }
      ]
    }
  ]
}
